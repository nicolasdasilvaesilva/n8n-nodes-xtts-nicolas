{
  "name": "n8n-nodes-xtts-nicolas",
  "version": "1.0.3",
  "description": "Custom XTTS node for n8n",
  "keywords": [
    "n8ncommunity-node-package"
  ],
  "license": "MIT",
  "homepage": "",
  "author": {
    "name": "Nicolas da Silva",
    "email": "nicolas@nicolasdasilva.com.br"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/XttsApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Xtts/Xtts.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.11",
    "@types/request-promise-native": "~1.0.15",
    "@typescript-eslint/parser": "~5.4.0",
    "eslint-plugin-n8n-nodes-base": "^1.11.0",
    "gulp": "^4.0.2",
    "n8n-workflow": "^0.137.0",
    "n8n-core": "^0.137.0",
    "prettier": "^2.4.1",
    "typescript": "^4.8.4"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
